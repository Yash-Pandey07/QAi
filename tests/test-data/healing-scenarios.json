[
  {
    "name": "Broken email input selector",
    "testId": "login-form-data-001-heal",
    "timeoutMs": 300000,
    "steps": [
      {
        "action": "goto",
        "target": "https://swag-testing.vercel.app/"
      },
      {
        "action": "fill",
        "target": "[data-testid=\"email-input-v3\"]",
        "value": "john@mail.com",
        "description": "Email address input field on login form"
      },
      {
        "action": "fill",
        "target": "input[type=\"password\"]",
        "value": "changeme",
        "description": "Password input field"
      },
      {
        "action": "click",
        "target": "button:has-text(\"Login\")",
        "description": "Login button"
      }
    ],
    "expectations": {
      "urlPattern": "/\\/inventory/",
      "selectorVisible": "a.font-bold",
      "expectedHeal": true
    }
  },
